{
  "name": "loveserenespaces",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma migrate deploy && npx prisma generate --no-engine && next build",
    "start": "npx prisma migrate deploy && npx prisma generate --no-engine && next start -p 3000",
    "build:analyze": "ANALYZE=true npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "next lint",
    "db:seed": "tsx prisma/seed.ts",
    "db:apply-contact": "npx prisma db execute --file prisma/sql/apply-contact-inquiry.sql --schema prisma/schema.prisma",
    "db:diff-to-schema": "node scripts/diff-db-to-schema.mjs",
    "db:reset": "npx prisma migrate reset --force",
    "hash-admin-password": "node scripts/hash-admin-password.mjs",
    "postinstall": "npx prisma generate --no-engine"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@heroicons/react": "^2.2.0",
    "@next/third-parties": "15.5.14",
    "@prisma/client": "^6.19.2",
    "@prisma/extension-accelerate": "^2.0.2",
    "@types/nodemailer": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "googleapis": "^156.0.0",
    "next": "15.5.14",
    "next-auth": "^5.0.0-beta.29",
    "nodemailer": "^7.0.7",
    "prisma": "^6.19.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-icons": "^5.5.0",
    "swr": "^2.3.6",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "15.5.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.8.32",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "null-loader": "^4.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "@auth/core": "0.41.1",
    "effect": "^3.20.1"
  }
}
